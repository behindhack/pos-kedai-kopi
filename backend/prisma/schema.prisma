// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
}

enum Role {
  OWNER
  CASHIER
  BARISTA
}

enum ProductCategory {
  ESPRESSO
  MANUAL_BREW
  NON_COFFEE
  FOOD
}

enum RawMaterialCategory {
  COFFEE_BEAN
  INGREDIENT
  EQUIPMENT
  PACKAGING
  OTHER
}

enum OrderType {
  DINE_IN
  TAKE_AWAY
}

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
}

enum SaleStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
}

model User {
  id                   Int       @id @default(autoincrement())
  email                String    @unique @db.VarChar(255)
  passwordHash         String    @map("password_hash") @db.VarChar(255)
  name                 String    @db.VarChar(255)
  role                 Role      @default(CASHIER)
  isActive             Boolean   @default(true) @map("is_active")
  resetPasswordToken   String?   @map("reset_password_token") @db.VarChar(255)
  resetPasswordExpires DateTime? @map("reset_password_expires")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model RawMaterial {
  id          Int                 @id @default(autoincrement())
  name        String              @db.VarChar(255)
  category    RawMaterialCategory @default(INGREDIENT)
  quantity    Decimal             @default(0) @db.Decimal(10, 3)
  unit        String              @db.VarChar(50)
  minQuantity Decimal             @default(0) @map("min_quantity") @db.Decimal(10, 3)
  costPerUnit Decimal             @default(0) @map("cost_per_unit") @db.Decimal(15, 2)
  supplier    String?             @db.VarChar(255)
  totalCost   Decimal             @default(0) @map("total_cost") @db.Decimal(15, 2)
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  productRecipes ProductRecipe[]

  @@map("raw_materials")
}

model Product {
  id        Int             @id @default(autoincrement())
  name      String          @db.VarChar(255)
  category  ProductCategory
  basePrice Decimal         @map("base_price") @db.Decimal(15, 2)
  image     String?         @db.LongText
  stock     Decimal         @default(0) @db.Decimal(10, 3)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  variants ProductVariant[]
  recipe   ProductRecipe[]

  @@map("products")
}

model ProductVariant {
  id         Int     @id @default(autoincrement())
  productId  Int     @map("product_id")
  name       String  @db.VarChar(255)
  extraPrice Decimal @default(0) @map("extra_price") @db.Decimal(15, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model ProductRecipe {
  id         Int     @id @default(autoincrement())
  productId  Int     @map("product_id")
  materialId Int     @map("material_id")
  quantity   Decimal @db.Decimal(10, 3)

  product  Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  material RawMaterial @relation(fields: [materialId], references: [id])

  @@map("product_recipes")
}

model Sale {
  id           Int           @id @default(autoincrement())
  orderNumber  String        @unique @map("order_number") @db.VarChar(50)
  customerName String?       @map("customer_name") @db.VarChar(255)
  orderType    OrderType     @map("order_type")
  subtotal     Decimal       @db.Decimal(15, 2)
  discount     Decimal       @default(0) @db.Decimal(15, 2)
  tax          Decimal       @default(0) @db.Decimal(15, 2)
  total        Decimal       @db.Decimal(15, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paidAmount   Decimal       @map("paid_amount") @db.Decimal(15, 2)
  changeAmount Decimal       @map("change_amount") @db.Decimal(15, 2)
  status       SaleStatus    @default(PENDING)
  date         DateTime      @default(now())
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  items SaleItem[]

  @@map("sales")
}

model SaleItem {
  id              Int     @id @default(autoincrement())
  saleId          Int     @map("sale_id")
  productId       Int     @map("product_id")
  productName     String  @map("product_name") @db.VarChar(255)
  productCategory String? @map("product_category") @db.VarChar(100)
  basePrice       Decimal @map("base_price") @db.Decimal(15, 2)
  qty             Int
  note            String? @db.Text

  sale     Sale              @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variants SaleItemVariant[]

  @@map("sale_items")
}

model SaleItemVariant {
  id         Int     @id @default(autoincrement())
  saleItemId Int     @map("sale_item_id")
  variantId  String  @map("variant_id") @db.VarChar(100)
  name       String  @db.VarChar(255)
  extraPrice Decimal @default(0) @map("extra_price") @db.Decimal(15, 2)

  saleItem SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Cascade)

  @@map("sale_item_variants")
}

model FinancialReport {
  id                    Int      @id @default(autoincrement())
  startDate             DateTime @map("start_date")
  endDate               DateTime @map("end_date")
  grossRevenue          Decimal  @default(0) @map("gross_revenue") @db.Decimal(15, 2)
  discounts             Decimal  @default(0) @db.Decimal(15, 2)
  taxes                 Decimal  @default(0) @db.Decimal(15, 2)
  netRevenue            Decimal  @default(0) @map("net_revenue") @db.Decimal(15, 2)
  openingStock          Decimal  @default(0) @map("opening_stock") @db.Decimal(15, 2)
  purchases             Decimal  @default(0) @db.Decimal(15, 2)
  closingStock          Decimal  @default(0) @map("closing_stock") @db.Decimal(15, 2)
  cogs                  Decimal  @default(0) @db.Decimal(15, 2)
  utilities             Decimal  @default(0) @db.Decimal(15, 2)
  rent                  Decimal  @default(0) @db.Decimal(15, 2)
  payroll               Decimal  @default(0) @db.Decimal(15, 2)
  otherExpenses         Decimal  @default(0) @map("other_expenses") @db.Decimal(15, 2)
  totalOperatingExpenses Decimal @default(0) @map("total_operating_expenses") @db.Decimal(15, 2)
  grossProfit           Decimal  @default(0) @map("gross_profit") @db.Decimal(15, 2)
  operatingProfit       Decimal  @default(0) @map("operating_profit") @db.Decimal(15, 2)
  netProfit             Decimal  @default(0) @map("net_profit") @db.Decimal(15, 2)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("financial_reports")
}

model Setting {
  id                Int      @id @default(autoincrement())
  name              String   @default("Kedai Kopi") @db.VarChar(255)
  shopLogo          String   @default("☕") @map("shop_logo") @db.VarChar(10)
  address           String   @db.Text
  phone             String   @default("081234567890") @db.VarChar(50)
  receiptPrinterIp  String?  @map("receipt_printer_ip") @db.VarChar(100)
  printShowLogo     Boolean  @default(true) @map("print_show_logo")
  printShowAddress  Boolean  @default(true) @map("print_show_address")
  printPaperWidth   Int      @default(80) @map("print_paper_width")
  taxPercent        Decimal  @default(0) @map("tax_percent") @db.Decimal(5, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
